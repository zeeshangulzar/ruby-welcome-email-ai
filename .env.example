# ─── Mailtrap Email API ───────────────────────────────────────────────────────
# API token from: Mailtrap → Settings → API Tokens (needs the "Admin" scope on
# your sending domain).
MAILTRAP_API_TOKEN=your_mailtrap_api_token

# Verified sender address. During development you can use the free demo domain:
#   hello@demomailtrap.co  (emails will only reach your Mailtrap account email)
# For production, use an address on your own verified sending domain.
MAILTRAP_FROM_EMAIL=hello@demomailtrap.co

# UUID of the transactional template you created in Mailtrap → Templates.
# The template must use these variables:
#   {{user_name}}  {{headline}}  {{body}}  {{cta_text}}  {{cta_url}}
MAILTRAP_WELCOME_TEMPLATE_UUID=your_template_uuid

# Optional — the URL used in the welcome email's CTA button
APP_DASHBOARD_URL=https://example.com/dashboard

# ─── Anthropic API ────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key
