# ─── Mailtrap ─────────────────────────────────────────────────────────────────
# API token from: Mailtrap → Settings → API Tokens
# Needs the "Admin" scope on your sending domain (for production) or on the
# sandbox project (for sandbox mode). A single token can cover both.
MAILTRAP_API_TOKEN=your_mailtrap_api_token

# Which Mailtrap endpoint to route through:
#   sandbox     — safe test inbox; emails are captured, never delivered to real
#                 recipients. Ideal for previewing AI-generated copy in dev.
#   production  — real email delivery via the Mailtrap Email API through your
#                 verified sending domain.
MAILTRAP_ENV=sandbox

# Sandbox inbox ID — required only when MAILTRAP_ENV=sandbox.
# Get from: Mailtrap → Sandboxes → your inbox → SMTP/API Integrations.
MAILTRAP_SANDBOX_INBOX_ID=your_sandbox_inbox_id

# Sender address for production sending — must be on a verified domain.
# During development you can use the free demo domain (hello@demomailtrap.co),
# which will only deliver to your Mailtrap account owner email.
MAILTRAP_FROM_EMAIL=hello@demomailtrap.co

# UUID of the transactional template you created in Mailtrap → Templates.
# The template must use these variables:
#   {{user_name}}  {{headline}}  {{body}}  {{cta_text}}  {{cta_url}}
MAILTRAP_WELCOME_TEMPLATE_UUID=your_template_uuid

# Optional — the URL used in the welcome email's CTA button
APP_DASHBOARD_URL=https://example.com/dashboard

# ─── Anthropic API ────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key
