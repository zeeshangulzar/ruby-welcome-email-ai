<div class="success-card">
  <div class="check">✓</div>
  <h1>You're in, <%= @user.name %>!</h1>

  <% if @user.welcome_email_status == "sent" %>
    <p>Your AI-personalized welcome email is on its way to <strong><%= @user.email %></strong>.</p>
  <% elsif @user.welcome_email_status == "failed" %>
    <p class="warn">Your account is created, but we couldn't deliver the welcome email right now — check server logs.</p>
  <% else %>
    <p>Your account is created. The welcome email is queued.</p>
  <% end %>

  <p><%= link_to "Sign up another user", signup_path, class: "back-link" %></p>
</div>

<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif; background: #f6f6f6; margin: 0; padding: 48px 24px; color: #222; }
  .success-card { max-width: 480px; margin: 0 auto; background: #fff; border-radius: 8px; padding: 40px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,.05); }
  .check { font-size: 48px; color: #22c55e; margin-bottom: 8px; }
  .success-card h1 { margin: 0 0 12px 0; }
  .success-card p { color: #555; }
  .warn { color: #b45309; }
  .back-link { color: #635bff; text-decoration: none; font-weight: 600; }
</style>
