<div class="signup-card">
  <h1>Sign up for ACME</h1>
  <p class="lead">Get an AI-personalized welcome email in your inbox in seconds.</p>

  <%= form_with model: @user, url: signup_path, local: true, class: "signup-form" do |f| %>
    <% if @user.errors.any? %>
      <div class="errors">
        <strong>Please fix these errors:</strong>
        <ul>
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <label>
      Name
      <%= f.text_field :name, required: true, autofocus: true %>
    </label>

    <label>
      Email
      <%= f.email_field :email, required: true %>
    </label>

    <label>
      Role
      <%= f.select :role, User::ROLES.map { |r| [r.humanize, r] }, { prompt: "Select your role" }, required: true %>
    </label>

    <label>
      Company size
      <%= f.select :company_size, User::COMPANY_SIZES, { prompt: "Select company size" }, required: true %>
    </label>

    <label>
      What will you use ACME for?
      <%= f.text_area :use_case, rows: 3, placeholder: "e.g. Coordinating async engineering standups across 3 timezones." %>
    </label>

    <%= f.submit "Create account", class: "submit-button" %>
  <% end %>
</div>

<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif; background: #f6f6f6; margin: 0; padding: 48px 24px; color: #222; }
  .signup-card { max-width: 480px; margin: 0 auto; background: #fff; border-radius: 8px; padding: 32px; box-shadow: 0 2px 8px rgba(0,0,0,.05); }
  .signup-card h1 { margin: 0 0 8px 0; }
  .lead { color: #666; margin: 0 0 24px 0; }
  .signup-form label { display: block; margin-bottom: 16px; font-size: 14px; font-weight: 600; color: #333; }
  .signup-form input, .signup-form select, .signup-form textarea { display: block; width: 100%; margin-top: 6px; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; font-family: inherit; box-sizing: border-box; }
  .signup-form textarea { resize: vertical; }
  .submit-button { background: #635bff; color: #fff; border: none; padding: 12px 24px; border-radius: 6px; font-size: 15px; font-weight: 600; cursor: pointer; }
  .submit-button:hover { background: #524ae0; }
  .errors { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; padding: 12px 16px; border-radius: 6px; margin-bottom: 20px; font-size: 14px; }
  .errors ul { margin: 8px 0 0 20px; padding: 0; }
</style>
